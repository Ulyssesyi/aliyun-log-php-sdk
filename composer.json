{
  "readme": "README.md",
  "type": "library",
  "description": "The Php SDK of Alibaba log service",
  "keywords": [
    "sdk",
    "sls",
    "alibaba"
  ],
  "require": {
    "php": "^8.1",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-zlib": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.2",
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpstan/phpstan": "^2.2"
  },
  "authors": [
    {
      "name": "Qi Zhou"
    },
    {
      "name": "TingTao Sun"
    },
    {
      "name": "Leiyun Ma"
    },
    {
      "name": "Xin Zhang"
    }
  ],
  "scripts": {
    "cs-fix": "php-cs-fixer fix",
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "phpstan": "phpstan analyse -c phpstan.neon.dist",
    "check": [
      "@cs-check",
      "@phpstan"
    ],
    "fix": "@cs-fix"
  },
  "autoload": {
    "psr-4": {
      "Aliyun\\Log\\": "Aliyun/Log/"
    }
  },
  "name": "sabao/aliyun-log-php-sdk",
  "license": "MIT",
  "version": "0.7.0"
}
